[resource]
script = ExtResource("2_qpk4h")
name = "Verordnung zur zeitlichen Nutzungsbeschränkung von Kraftfahrzeugen nach Endziffern"
text = "Zur Reduzierung des täglichen Verkehrsaufkommens wird die Nutzung von Kraftfahrzeugen mit geraden Endziffern auf gerade Kalenderwochen beschränkt. Kraftfahrzeuge mit ungeraden Endziffern dürfen entsprechend nur in ungeraden Kalenderwochen betrieben werden."
